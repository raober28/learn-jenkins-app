pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                }
            }
            environment {
                NODE_EXTRA_CA_CERTS = 'zscaler.crt'
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version

                    # Trust Zscaler cert during this session
                    npm config set cafile=$NODE_EXTRA_CA_CERTS


                    npm install
                    npm run build
                    ls -la
                '''
            }
        }
    }
}
