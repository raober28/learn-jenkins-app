pipeline {
    agent any

    stages {
         stage('Trust Zs Cert') {
            steps {
                sh '''
                    # Copy the cert inside the system trust store
                    cp zscaler.crt /usr/local/share/ca-certificates/zscaler.crt

                    # Update certs to trust Zscaler
                    update-ca-certificates
                '''
            }
        }
        stage('Build') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm install
                    npm run build
                    ls -la
                '''
            }
        }
    }
}
