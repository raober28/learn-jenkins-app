pipeline {
    agent {
        docker {
        image 'node:18'
        reuseNode true
        }
    }

    stages {
    stage('Install & Build') {
      steps {
        // Make sure zscaler.crt is in your Git repo root
        sh '''
           

          echo "Installing dependencies"
          npm install

          echo "Building the app"
          npm run build
        '''
      }
    }
  }
}
